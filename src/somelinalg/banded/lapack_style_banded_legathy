use super::{error::BandedError, ops::banded_matvec, storage::Banded};

/// Unblocked LAPACK-style LU factorization for a square banded matrix.
///
/// Storage follows the LAPACK GB workspace idea:
///   ldab = 2*kl + ku + 1
///   kv   = kl + ku
///
/// Physical A(i, j) is stored at:
///   ab[kv + i - j, j]
///
/// This workspace is larger than compact band storage because the upper
/// fill-in created by row pivoting must be preserved.
#[derive(Clone, Debug)]
pub struct LapackStyleBandedLu {
    n: usize,
    kl: usize,
    ku: usize,
    kv: usize,
    ldab: usize,
    ab: Vec<f64>,     // column-major: row + col * ldab
    ipiv: Vec<usize>, // 0-based pivot rows
    is_factorized: bool,
    pivot_epsilon: f64,
}

impl LapackStyleBandedLu {
    pub fn new(n: usize, kl: usize, ku: usize) -> Result<Self, BandedError> {
        if n == 0 {
            return Err(BandedError::DimensionMismatch);
        }

        let kv = kl.checked_add(ku).ok_or(BandedError::DimensionMismatch)?;
        let ldab = kl
            .checked_mul(2)
            .and_then(|x| x.checked_add(ku))
            .and_then(|x| x.checked_add(1))
            .ok_or(BandedError::DimensionMismatch)?;

        let len = ldab.checked_mul(n).ok_or(BandedError::DimensionMismatch)?;

        Ok(Self {
            n,
            kl,
            ku,
            kv,
            ldab,
            ab: vec![0.0; len],
            ipiv: vec![0; n],
            is_factorized: false,
            pivot_epsilon: 1e-14,
        })
    }

    #[inline]
    pub fn n(&self) -> usize {
        self.n
    }

    #[inline]
    pub fn kl(&self) -> usize {
        self.kl
    }

    #[inline]
    pub fn ku(&self) -> usize {
        self.ku
    }

    #[inline]
    pub fn kv(&self) -> usize {
        self.kv
    }

    #[inline]
    pub fn ldab(&self) -> usize {
        self.ldab
    }

    #[inline]
    pub fn ipiv(&self) -> &[usize] {
        &self.ipiv
    }

    #[inline]
    pub fn is_factorized(&self) -> bool {
        self.is_factorized
    }

    #[inline]
    pub fn set_pivot_epsilon(&mut self, eps: f64) {
        self.pivot_epsilon = eps;
    }

    #[inline]
    fn ab_index(&self, row: usize, col: usize) -> usize {
        row + col * self.ldab
    }

    #[inline]
    fn get_ab(&self, row: usize, col: usize) -> f64 {
        self.ab[self.ab_index(row, col)]
    }

    #[inline]
    fn set_ab(&mut self, row: usize, col: usize, value: f64) {
        let idx = self.ab_index(row, col);
        self.ab[idx] = value;
    }

    #[inline]
    pub fn workspace(&self) -> &[f64] {
        &self.ab
    }

    #[inline]
    pub fn workspace_mut(&mut self) -> &mut [f64] {
        &mut self.ab
    }

    /// Map physical matrix entry A(i, j) to workspace row index.
    ///
    /// Returns None if the entry lies outside the representable LU band workspace.
    #[inline]
    fn phys_to_ab_row(&self, i: usize, j: usize) -> Option<usize> {
        let row = self.kv as isize + i as isize - j as isize;
        if row < 0 || row >= self.ldab as isize {
            None
        } else {
            Some(row as usize)
        }
    }

    /// Returns whether physical A(i,j) is storable in the current workspace.
    #[inline]
    fn is_representable(&self, i: usize, j: usize) -> bool {
        self.phys_to_ab_row(i, j).is_some()
    }

    #[inline]
    pub fn get_phys(&self, i: usize, j: usize) -> f64 {
        self.phys_to_ab_row(i, j)
            .map(|row| self.get_ab(row, j))
            .unwrap_or(0.0)
    }

    #[inline]
    pub fn set_phys(&mut self, i: usize, j: usize, value: f64) {
        if let Some(row) = self.phys_to_ab_row(i, j) {
            self.set_ab(row, j, value);
        }
    }

    /// Zero whole workspace and load a compact banded matrix into LAPACK-style GB workspace.
    ///
    /// Compact Banded<f64> stores A(i,j) only on the original band.
    /// Here we place it into rows kv + i - j.
    pub fn load_from_banded(&mut self, a: &Banded<f64>) -> Result<(), BandedError> {
        if a.n() != self.n || a.kl() != self.kl || a.ku() != self.ku {
            return Err(BandedError::DimensionMismatch);
        }

        self.ab.fill(0.0);
        self.ipiv.fill(0);
        self.is_factorized = false;

        let n = self.n;
        for j in 0..n {
            let i0 = j.saturating_sub(self.ku);
            let i1 = (j + self.kl + 1).min(n);

            for i in i0..i1 {
                let v = a[(i, j)];
                self.set_phys(i, j, v);
            }
        }

        Ok(())
    }

    pub fn solve_in_place_with_refinement<F>(
        &self,
        rhs: &mut [f64],
        max_iters: usize,
        tol: f64,
        mut matvec: F,
    ) -> Result<usize, BandedError>
    where
        F: FnMut(&[f64], &mut [f64]) -> Result<(), BandedError>,
    {
        if rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        let b = rhs.to_vec();
        self.solve_in_place(rhs)?;

        let n = rhs.len();
        let b_norm = vec_linf_norm(&b).max(1.0);
        let mut current_rr = f64::INFINITY;
        let mut residual = vec![0.0; n];
        let mut ax = vec![0.0; n];
        let mut delta = vec![0.0; n];
        let mut x_trial = vec![0.0; n];
        let mut accepted_steps = 0usize;

        for _ in 0..max_iters {
            ax.fill(0.0);
            matvec(rhs, &mut ax)?;

            let mut r_norm: f64 = 0.0;
            for i in 0..n {
                residual[i] = b[i] - ax[i];
                r_norm = r_norm.max(residual[i].abs());
            }

            let rel_res = r_norm / b_norm;
            if rel_res < tol {
                break;
            }
            if !current_rr.is_finite() {
                current_rr = rel_res;
            }

            delta.copy_from_slice(&residual);
            self.solve_in_place(&mut delta)?;

            x_trial.copy_from_slice(rhs);
            for i in 0..n {
                x_trial[i] += delta[i];
            }

            ax.fill(0.0);
            matvec(&x_trial, &mut ax)?;

            let mut trial_r_norm: f64 = 0.0;
            for i in 0..n {
                trial_r_norm = trial_r_norm.max((b[i] - ax[i]).abs());
            }

            let trial_rr = trial_r_norm / b_norm;
            if !trial_rr.is_finite() || trial_rr >= current_rr {
                break;
            }

            rhs.copy_from_slice(&x_trial);
            current_rr = trial_rr;
            accepted_steps += 1;
        }

        Ok(accepted_steps)
    }

    pub fn solve_banded_in_place_with_refinement(
        &self,
        a: &Banded<f64>,
        rhs: &mut [f64],
        max_iters: usize,
        tol: f64,
    ) -> Result<usize, BandedError> {
        if a.n() != self.n || a.kl() != self.kl || a.ku() != self.ku || rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        self.solve_in_place_with_refinement(rhs, max_iters, tol, |x, ax| {
            let y = banded_matvec(a, x)?;
            if y.len() != ax.len() {
                return Err(BandedError::DimensionMismatch);
            }
            ax.copy_from_slice(&y);
            Ok(())
        })
    }

    /// For debugging: reconstruct the currently stored physical matrix from workspace.
    ///
    /// This includes fill-in currently present in the GB workspace, not just the original band.
    pub fn reconstruct_dense_from_workspace(&self) -> Vec<Vec<f64>> {
        let mut out = vec![vec![0.0; self.n]; self.n];

        for j in 0..self.n {
            // rows represented in this column by the workspace
            let i0 = j.saturating_sub(self.kv);
            let i1 = (j + (self.ldab - 1 - self.kv) + 1).min(self.n);

            for i in i0..i1 {
                if let Some(row) = self.phys_to_ab_row(i, j) {
                    out[i][j] = self.get_ab(row, j);
                }
            }
        }

        out
    }

    /// Original compact-band interpretation only (useful before factorization).
    pub fn reconstruct_original_band_dense(&self) -> Vec<Vec<f64>> {
        let mut out = vec![vec![0.0; self.n]; self.n];

        for j in 0..self.n {
            let i0 = j.saturating_sub(self.ku);
            let i1 = (j + self.kl + 1).min(self.n);

            for i in i0..i1 {
                out[i][j] = self.get_phys(i, j);
            }
        }

        out
    }

    /// Row swap restricted to columns where at least one of the rows is represented.
    ///
    /// This is intentionally simple and debug-friendly for the first unblocked implementation.
    fn swap_phys_rows_in_active_window(
        &mut self,
        r1: usize,
        r2: usize,
        col_lo: usize,
        col_hi: usize,
    ) {
        if r1 == r2 {
            return;
        }

        for col in col_lo..=col_hi {
            let x = self.get_phys(r1, col);
            let y = self.get_phys(r2, col);
            self.set_phys(r1, col, y);
            self.set_phys(r2, col, x);
        }
    }

    /// Zero the fill-in region of column `j_fill` that LAPACK keeps available above the original band.
    ///
    /// For the first version this is a simple helper; correctness is more important than elegance.
    fn zero_fill_column(&mut self, j_fill: usize) {
        if j_fill >= self.n {
            return;
        }

        // Top KL rows of the workspace are fill rows.
        for row in 0..self.kl {
            self.set_ab(row, j_fill, 0.0);
        }
    }

    /// Find pivot in column j among rows j..min(j+kl, n-1).
    ///
    /// Returns offset jp such that pivot row = j + jp.
    fn pivot_offset_in_column(&self, j: usize) -> usize {
        let km = (self.n - 1 - j).min(self.kl);

        let mut best_off = 0usize;
        let mut best_val = self.get_phys(j, j).abs();

        for off in 1..=km {
            let val = self.get_phys(j + off, j).abs();
            if val > best_val {
                best_val = val;
                best_off = off;
            }
        }

        best_off
    }

    /// Unblocked in-band LU with partial pivoting.
    ///
    /// This is the Rust "DGBTF2-style" first target, not the blocked DGBTRF mirror.
    pub fn factor_from(&mut self, a: &Banded<f64>) -> Result<(), BandedError> {
        self.load_from_banded(a)?;

        let n = self.n;
        let kl = self.kl;
        let ku = self.ku;
        let kv = self.kv;

        let mut ju = 0usize;

        for j in 0..n {
            let j_kv = j + kv;
            if j_kv < n {
                self.zero_fill_column(j_kv);
            }

            let km = (n - 1 - j).min(kl);
            let jp = self.pivot_offset_in_column(j);
            let piv_row = j + jp;
            self.ipiv[j] = piv_row;

            let pivot = self.get_phys(piv_row, j);
            if pivot.abs() <= self.pivot_epsilon {
                return Err(BandedError::ZeroPivot {
                    index: j,
                    value: pivot,
                });
            }

            ju = ju.max((j + ku + jp).min(n - 1));

            if piv_row != j {
                let col_lo = j.saturating_sub(kv);
                let col_hi = ju;
                self.swap_phys_rows_in_active_window(j, piv_row, col_lo, col_hi);
            }

            let pivot_now = self.get_phys(j, j);

            // multipliers
            for off in 1..=km {
                let i = j + off;
                let lij = self.get_phys(i, j) / pivot_now;
                self.set_phys(i, j, lij);
            }

            // rank-1 update inside active band region
            for col in (j + 1)..=ju {
                let u_jc = self.get_phys(j, col);
                if u_jc == 0.0 {
                    continue;
                }

                let i_hi = (j + km).min(n - 1);
                for i in (j + 1)..=i_hi {
                    let lij = self.get_phys(i, j);
                    if lij != 0.0 {
                        let new_val = self.get_phys(i, col) - lij * u_jc;
                        self.set_phys(i, col, new_val);
                    }
                }
            }
        }

        self.is_factorized = true;
        Ok(())
    }
    pub fn debug_dump_dense(&self) -> Vec<Vec<f64>> {
        self.reconstruct_dense_from_workspace()
    }

    /// Reconstruct dense lower triangular factor L.
    ///
    /// L has unit diagonal and at most KL subdiagonals.
    pub fn reconstruct_l_dense(&self) -> Result<Vec<Vec<f64>>, BandedError> {
        if !self.is_factorized {
            return Err(BandedError::NotFactorized);
        }

        let n = self.n;
        let mut l = vec![vec![0.0; n]; n];

        for i in 0..n {
            l[i][i] = 1.0;
        }

        for j in 0..n {
            let i_hi = (j + self.kl).min(n - 1);
            for i in (j + 1)..=i_hi {
                l[i][j] = self.get_phys(i, j);
            }
        }

        Ok(l)
    }

    /// Reconstruct dense upper factor U.
    ///
    /// U may have up to KV = KL + KU superdiagonals because of fill-in.
    pub fn reconstruct_u_dense(&self) -> Result<Vec<Vec<f64>>, BandedError> {
        if !self.is_factorized {
            return Err(BandedError::NotFactorized);
        }

        let n = self.n;
        let mut u = vec![vec![0.0; n]; n];

        for j in 0..n {
            let i0 = j.saturating_sub(self.kv);
            let i1 = j.min(n - 1);

            for i in i0..=i1 {
                u[i][j] = self.get_phys(i, j);
            }
        }

        Ok(u)
    }

    /// Apply the recorded row pivots to the original matrix A and return P*A.
    ///
    /// This uses the same sequential swap interpretation as the factorization loop.
    pub fn reconstruct_pa_dense(&self, a: &Banded<f64>) -> Result<Vec<Vec<f64>>, BandedError> {
        if a.n() != self.n || a.kl() != self.kl || a.ku() != self.ku {
            return Err(BandedError::DimensionMismatch);
        }

        let n = self.n;
        let mut pa = vec![vec![0.0; n]; n];

        for j in 0..n {
            let i0 = j.saturating_sub(self.ku);
            let i1 = (j + self.kl + 1).min(n);

            for i in i0..i1 {
                pa[i][j] = a[(i, j)];
            }
        }

        if self.is_factorized {
            for j in 0..n {
                let p = self.ipiv[j];
                if p != j {
                    pa.swap(j, p);
                }
            }
        }

        Ok(pa)
    }

    pub fn factor_residual_inf(&self, a: &Banded<f64>) -> Result<f64, BandedError> {
        let pa = self.reconstruct_pa_dense(a)?;
        let l = self.reconstruct_l_dense()?;
        let u = self.reconstruct_u_dense()?;
        let lu = dense_matmul(&l, &u);

        Ok(dense_linf_diff(&pa, &lu))
    }

    pub fn factor_residual_relative(&self, a: &Banded<f64>) -> Result<f64, BandedError> {
        let pa = self.reconstruct_pa_dense(a)?;
        let l = self.reconstruct_l_dense()?;
        let u = self.reconstruct_u_dense()?;
        let lu = dense_matmul(&l, &u);

        let num = dense_linf_diff(&pa, &lu);
        let den = dense_linf_norm(&pa).max(dense_linf_norm(&lu)).max(1.0);

        Ok(num / den)
    }

    fn apply_row_interchanges_rhs_in_place(&self, rhs: &mut [f64]) -> Result<(), BandedError> {
        if rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        for j in 0..self.n {
            let p = self.ipiv[j];
            if p != j {
                rhs.swap(j, p);
            }
        }

        Ok(())
    }

    fn forward_solve_l_in_place(&self, rhs: &mut [f64]) -> Result<(), BandedError> {
        if rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        let n = self.n;
        let kl = self.kl;

        if kl == 0 || n <= 1 {
            return Ok(());
        }

        for j in 0..(n - 1) {
            let lm = kl.min(n - 1 - j);
            let bj = rhs[j];

            if bj == 0.0 {
                continue;
            }

            for off in 1..=lm {
                let i = j + off;
                let lij = self.get_phys(i, j);
                if lij != 0.0 {
                    rhs[i] -= lij * bj;
                }
            }
        }

        Ok(())
    }
    fn backward_solve_u_in_place(&self, rhs: &mut [f64]) -> Result<(), BandedError> {
        if rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        let n = self.n;
        let kv = self.kv;

        for i in (0..n).rev() {
            let j_hi = (i + kv).min(n - 1);

            let mut sum = rhs[i];
            for j in (i + 1)..=j_hi {
                let uij = self.get_phys(i, j);
                if uij != 0.0 {
                    sum -= uij * rhs[j];
                }
            }

            let uii = self.get_phys(i, i);
            if uii.abs() <= self.pivot_epsilon {
                return Err(BandedError::ZeroPivot {
                    index: i,
                    value: uii,
                });
            }

            rhs[i] = sum / uii;
        }

        Ok(())
    }
    pub fn solve_in_place(&self, rhs: &mut [f64]) -> Result<(), BandedError> {
        if !self.is_factorized {
            return Err(BandedError::NotFactorized);
        }
        if rhs.len() != self.n {
            return Err(BandedError::DimensionMismatch);
        }

        self.apply_row_interchanges_rhs_in_place(rhs)?;
        self.forward_solve_l_in_place(rhs)?;
        self.backward_solve_u_in_place(rhs)?;

        Ok(())
    }

    pub fn solve_multiple_in_place(
        &self,
        rhs: &mut [f64],
        nrhs: usize,
        ldb: usize,
    ) -> Result<(), BandedError> {
        if !self.is_factorized {
            return Err(BandedError::NotFactorized);
        }
        if ldb < self.n || rhs.len() < nrhs.saturating_mul(ldb) {
            return Err(BandedError::DimensionMismatch);
        }

        for col in 0..nrhs {
            let start = col * ldb;
            let end = start + self.n;
            self.solve_in_place(&mut rhs[start..end])?;
        }

        Ok(())
    }

    pub fn solve_with_refinement(
        &self,
        a: &Banded<f64>, // нужна для matvec
        b: &[f64],
        max_iters: usize,
        tol: f64,
    ) -> Result<Vec<f64>, BandedError> {
        let n = b.len();

        // 1. initial solve
        let mut x = b.to_vec();
        self.solve_in_place(&mut x)?;

        let mut r = vec![0.0; n];
        let mut delta = vec![0.0; n];

        for _ in 0..max_iters {
            // r = b - A x
            let ax = banded_matvec(a, &x).unwrap();

            let mut r_norm: f64 = 0.0;
            let mut b_norm: f64 = 0.0;

            for i in 0..n {
                r[i] = b[i] - ax[i];
                r_norm = r_norm.max(r[i].abs());
                b_norm = b_norm.max(b[i].abs());
            }

            let rel_res = r_norm / b_norm.max(1.0);

            // stop condition
            if rel_res < tol {
                break;
            }

            // solve A δ = r
            delta.copy_from_slice(&r);
            self.solve_in_place(&mut delta)?;

            // x += δ
            for i in 0..n {
                x[i] += delta[i];
            }
        }

        Ok(x)
    }

    fn max_abs_multiplier_in_column(&self, j: usize) -> f64 {
        let km = (self.n - 1 - j).min(self.kl);
        let mut m: f64 = 0.0;

        for off in 1..=km {
            let i = j + off;
            m = m.max(self.get_phys(i, j).abs());
        }

        m
    }

    fn max_abs_in_active_region(
        &self,
        row_lo: usize,
        row_hi: usize,
        col_lo: usize,
        col_hi: usize,
    ) -> f64 {
        let mut m: f64 = 0.0;

        for col in col_lo..=col_hi {
            for row in row_lo..=row_hi {
                m = m.max(self.get_phys(row, col).abs());
            }
        }

        m
    }

    pub fn factor_from_with_diagnostics(
        &mut self,
        a: &Banded<f64>,
    ) -> Result<Vec<FactorStepDiagnostics>, BandedError> {
        self.load_from_banded(a)?;

        let n = self.n;
        let kl = self.kl;
        let ku = self.ku;
        let kv = self.kv;

        let mut ju = 0usize;
        let mut diag = Vec::with_capacity(n);

        for j in 0..n {
            let j_kv = j + kv;
            if j_kv < n {
                self.zero_fill_column(j_kv);
            }

            let km = (n - 1 - j).min(kl);
            let jp = self.pivot_offset_in_column(j);
            let piv_row = j + jp;
            self.ipiv[j] = piv_row;

            let pivot_before_swap = self.get_phys(piv_row, j);
            if pivot_before_swap.abs() <= self.pivot_epsilon {
                return Err(BandedError::ZeroPivot {
                    index: j,
                    value: pivot_before_swap,
                });
            }

            ju = ju.max((j + ku + jp).min(n - 1));

            if piv_row != j {
                let col_lo = j.saturating_sub(kv);
                let col_hi = ju;
                self.swap_phys_rows_in_active_window(j, piv_row, col_lo, col_hi);
            }

            let pivot_now = self.get_phys(j, j);

            for off in 1..=km {
                let i = j + off;
                let lij = self.get_phys(i, j) / pivot_now;
                self.set_phys(i, j, lij);
            }

            for col in (j + 1)..=ju {
                let u_jc = self.get_phys(j, col);
                if u_jc == 0.0 {
                    continue;
                }

                let i_hi = (j + km).min(n - 1);
                for i in (j + 1)..=i_hi {
                    let lij = self.get_phys(i, j);
                    if lij != 0.0 {
                        let new_val = self.get_phys(i, col) - lij * u_jc;
                        self.set_phys(i, col, new_val);
                    }
                }
            }

            let max_abs_multiplier = self.max_abs_multiplier_in_column(j);
            let row_hi = (j + km).min(n - 1);
            let max_abs_active_entry = if j < ju {
                self.max_abs_in_active_region(j, row_hi, j, ju)
            } else {
                self.get_phys(j, j).abs()
            };

            diag.push(FactorStepDiagnostics {
                step: j,
                pivot_row: piv_row,
                ju,
                pivot_value: pivot_now,
                max_abs_multiplier,
                max_abs_active_entry,
                workspace_linf: slice_linf_norm(&self.ab),
            });
        }

        self.is_factorized = true;
        Ok(diag)
    }
}
