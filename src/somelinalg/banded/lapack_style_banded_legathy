pub fn row_scaled_banded_copy(a: &Banded<f64>) -> Banded<f64> {
    let n = a.n();
    let kl = a.kl();
    let ku = a.ku();

    let mut out = Banded::<f64>::zeros(n, kl, ku).unwrap();
    let mut row_scales = vec![0.0_f64; n];

    // compute row infinity norms
    for i in 0..n {
        let j0 = i.saturating_sub(kl);
        let j1 = (i + ku + 1).min(n);

        let mut s = 0.0_f64;
        for j in j0..j1 {
            s = s.max(a[(i, j)].abs());
        }

        row_scales[i] = if s > 0.0 { s } else { 1.0 };
    }

    // scale rows
    for j in 0..n {
        let i0 = j.saturating_sub(ku);
        let i1 = (j + kl + 1).min(n);

        for i in i0..i1 {
            out[(i, j)] = a[(i, j)] / row_scales[i];
        }
    }

    out
}

pub fn row_scaled_banded_copy_with_scales(a: &Banded<f64>) -> (Banded<f64>, Vec<f64>) {
    let n = a.n();
    let kl = a.kl();
    let ku = a.ku();

    let mut out = Banded::<f64>::zeros(n, kl, ku).unwrap();
    let mut row_scales = vec![0.0_f64; n];

    for i in 0..n {
        let j0 = i.saturating_sub(kl);
        let j1 = (i + ku + 1).min(n);

        let mut s = 0.0_f64;
        for j in j0..j1 {
            s = s.max(a[(i, j)].abs());
        }

        row_scales[i] = if s > 0.0 { s } else { 1.0 };
    }

    for j in 0..n {
        let i0 = j.saturating_sub(ku);
        let i1 = (j + kl + 1).min(n);

        for i in i0..i1 {
            out[(i, j)] = a[(i, j)] / row_scales[i];
        }
    }

    (out, row_scales)
}
pub fn apply_row_scales_to_rhs(rhs: &[f64], row_scales: &[f64]) -> Vec<f64> {
    assert_eq!(rhs.len(), row_scales.len());

    rhs.iter()
        .zip(row_scales.iter())
        .map(|(b, s)| b / s)
        .collect()
}
pub fn print_factor_diag_summary(diag: &[FactorStepDiagnostics]) {
    let min_pivot = diag
        .iter()
        .min_by(|a, b| {
            a.pivot_value
                .abs()
                .partial_cmp(&b.pivot_value.abs())
                .unwrap()
        })
        .unwrap();

    let max_mult = diag
        .iter()
        .max_by(|a, b| {
            a.max_abs_multiplier
                .partial_cmp(&b.max_abs_multiplier)
                .unwrap()
        })
        .unwrap();

    let max_active = diag
        .iter()
        .max_by(|a, b| {
            a.max_abs_active_entry
                .partial_cmp(&b.max_abs_active_entry)
                .unwrap()
        })
        .unwrap();

    let max_workspace = diag
        .iter()
        .max_by(|a, b| a.workspace_linf.partial_cmp(&b.workspace_linf).unwrap())
        .unwrap();

    eprintln!(
        "min pivot: step={}, piv_row={}, ju={}, pivot={:e}",
        min_pivot.step, min_pivot.pivot_row, min_pivot.ju, min_pivot.pivot_value
    );
    eprintln!(
        "max multiplier: step={}, piv_row={}, ju={}, max_mult={:e}",
        max_mult.step, max_mult.pivot_row, max_mult.ju, max_mult.max_abs_multiplier
    );
    eprintln!(
        "max active entry: step={}, piv_row={}, ju={}, max_active={:e}",
        max_active.step, max_active.pivot_row, max_active.ju, max_active.max_abs_active_entry
    );
    eprintln!(
        "max workspace inf: step={}, piv_row={}, ju={}, workspace_inf={:e}",
        max_workspace.step, max_workspace.pivot_row, max_workspace.ju, max_workspace.workspace_linf
    );
}

