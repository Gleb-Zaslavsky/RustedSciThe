pub fn extract_trailing_dense_block(a: &Banded<f64>, block_size: usize) -> Vec<Vec<f64>> {
    let n = a.n();
    assert!(block_size > 0);
    assert!(block_size <= n);

    let start = n - block_size;
    let mut out = vec![vec![0.0; block_size]; block_size];

    for local_j in 0..block_size {
        let j = start + local_j;

        let i0 = j.saturating_sub(a.ku()).max(start);
        let i1 = (j + a.kl() + 1).min(n);

        for i in i0..i1 {
            let local_i = i - start;
            out[local_i][local_j] = a[(i, j)];
        }
    }

    out
}

pub fn dense_linf_norm(a: &[Vec<f64>]) -> f64 {
    a.iter()
        .flat_map(|row| row.iter())
        .map(|x| x.abs())
        .fold(0.0_f64, f64::max)
}

pub fn dense_diag_abs_minmax(a: &[Vec<f64>]) -> (f64, f64) {
    let n = a.len();
    let mut mn: f64 = f64::INFINITY;
    let mut mx: f64 = 0.0;

    for i in 0..n {
        let v = a[i][i].abs();
        mn = mn.min(v);
        mx = mx.max(v);
    }

    (mn, mx)
}

