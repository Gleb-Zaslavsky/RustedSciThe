        let a = generate_bvp1d_banded(1000, 6, 2, 1, 123);
        let (_x_true, b) = generate_rhs_from_known_solution(&a, 777);

        let n = a.n();

        let mut lu = LapackStyleBandedLu::new(n, a.kl(), a.ku()).unwrap();
        lu.factor_from(&a).unwrap();

        // без refinement
        let mut x0 = b.clone();
        lu.solve_in_place(&mut x0).unwrap();
        let rr0 = relative_banded_residual(&a, &x0, &b);

        // с refinement
        let mut x_ref = b.clone();
        let accepted = lu
            .solve_banded_in_place_with_refinement(&a, &mut x_ref, 3, 1e-12)
            .unwrap();
        let rr_ref = relative_banded_residual(&a, &x_ref, &b);

        eprintln!("rr0 = {rr0:e}, rr_ref = {rr_ref:e}, accepted = {accepted}");

        assert!(rr_ref <= rr0);
    }
